   "source": [
    "def ncr(n,r):\n",
    "    res=1\n",
    "    for i in range(1,r+1):\n",
    "        res=res*(n-i+1)//i\n",
    "    return res\n",
    "n=int(input())\n",
    "r=int(input())\n",
    "t=ncr(n,r)\n",
    "one=ncr(n-1,r-1)\n",
    "print(t)\n",
    "print(one)"
   ]
