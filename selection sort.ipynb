   "source": [
    "def selection(a):\n",
    "    for i in range(len(a)):\n",
    "        mi=i\n",
    "        for j in range(i+1,len(a)):\n",
    "            if a[j]<a[mi]:\n",
    "                mi=j\n",
    "        a[i],a[mi]=a[mi],a[i]\n",
    "    return a\n",
    "a=list(map(int,input().split()))\n",
    "print(selection(a))"
   ]
