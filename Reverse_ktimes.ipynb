   "source": [
    "def reverse(a,s,e):\n",
    "  while s<e:\n",
    "    a[s],a[e]=a[e],a[s]\n",
    "    s+=1\n",
    "    e-=1\n",
    "def rotate(a,k):\n",
    "  n=len(a)\n",
    "  k=k%n\n",
    "  reverse(a,0,n-1)\n",
    "  reverse(a,0,k-1)\n",
    "  reverse(a,k,n-1)\n",
    "  return a\n",
    "a=list(map(int,input().split()))\n",
    "k=int(input())\n",
    "print(rotate(a,k))"
   ]
  },
