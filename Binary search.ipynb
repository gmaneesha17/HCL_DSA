   "source": [
    "def binary(a,t):\n",
    "    l=0\n",
    "    h=len(a)-1\n",
    "    while l<=h:\n",
    "        m=(l+h)//2\n",
    "        if a[m]==t:\n",
    "            return m\n",
    "        elif a[m]<t:\n",
    "            l=m+1\n",
    "        else:\n",
    "            h=m-1\n",
    "    return -1\n",
    "a=list(map(int,input().split()))\n",
    "t=int(input())\n",
    "print(binary(a,t))"
   ]
  },
