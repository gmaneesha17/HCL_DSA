   "source": [
    "def reverse_string(s,index=None):\n",
    "    if index is None:\n",
    "        index=len(s)-1\n",
    "    if index<0:\n",
    "        return \"\"\n",
    "    return s[index]+reverse_string(s,index-1)\n",
    "s=input()\n",
    "print(reverse_string(s))"
   ]
