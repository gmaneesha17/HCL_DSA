    "def linear(a,t):\n",
    "    for i in range(len(a)):\n",
    "        if a[i]==t:\n",
    "            return i\n",
    "    return -1\n",
    "a=list(map(int,input().split()))\n",
    "t=int(input())\n",
    "print(linear(a,t))"
   ]
