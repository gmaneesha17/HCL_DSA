   "source": [
    "def insertion(a):\n",
    "    for i in range(1,len(a)):\n",
    "        j=i-1\n",
    "        t=a[i]\n",
    "        while j>=0 and a[j]>t:\n",
    "            a[j+1]=a[j]\n",
    "            j-=1\n",
    "        a[j+1]=t\n",
    "    return a\n",
    "a=list(map(int,input().split()))\n",
    "print(insertion(a))"
   ]
