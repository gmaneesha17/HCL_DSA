   ],
   "source": [
    "import re\n",
    "\n",
    "def extract_phones(text):\n",
    "    pattern = r'(?:\\+91[\\s-]?)?[6-9]\\d{9}|\\(\\d{3}\\)\\s?\\d{3}-\\d{4}|\\d{3}-\\d{3}-\\d{4}'\n",
    "    return re.findall(pattern, text)\n",
    "\n",
    "\n",
    "text = input(\"Enter text: \")\n",
    "phones = extract_phones(text)\n",
    "\n",
    "print(\"Phone numbers found:\")\n",
    "for p in phones:\n",
    "    print(p)"
   ]
  },
