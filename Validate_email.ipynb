    "import re\n",
    "def validate(email):\n",
    "    p=r'^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$'\n",
    "    return bool(re.match(p,email))\n",
    "email=input()\n",
    "if validate(email):\n",
    "    print(\"Correct Email\")\n",
    "else:\n",
    "    print(\"Wrong Email\")"
   ]
  }
