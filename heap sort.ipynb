   "source": [
    "import heapq\n",
    "def heap(a):\n",
    "    heapq.heapify(a)\n",
    "    ans=[]\n",
    "    while a:\n",
    "        ans.append(heapq.heappop(a))\n",
    "    return ans\n",
    "a=list(map(int,input().split()))\n",
    "print(heap(a))"
   ]
