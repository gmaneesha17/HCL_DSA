   "source": [
    "def maxproduct(a):\n",
    "    mi=a[0]\n",
    "    ma=a[0]\n",
    "    r=a[0]\n",
    "    for i in range(1,len(a)):\n",
    "        n=a[i]\n",
    "        if n<0:\n",
    "            mi,ma=ma,mi\n",
    "        ma=max(ma,n*ma)\n",
    "        mi=min(mi,n*mi)\n",
    "        r=max(r,ma)\n",
    "    return r\n",
    "a=list(map(int,input().split()))\n",
    "print(maxproduct(a))"
   ]
  },
