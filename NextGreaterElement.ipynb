   "source": [
    "def nge(a):\n",
    "  n=len(a)\n",
    "  st=[]\n",
    "  r=[-1]*n\n",
    "  for i in range(n):\n",
    "    while st and a[st[-1]]<a[i]:\n",
    "      idx=st.pop()\n",
    "      r[idx]=a[i]\n",
    "    st.append(i)\n",
    "  return r\n",
    "a=list(map(int,input().split()))\n",
    "print(nge(a))"
   ]
