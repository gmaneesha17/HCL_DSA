   "source": [
    "def compress(s):\n",
    "    r=\"\"\n",
    "    c=1\n",
    "    for i in range(1,len(s)):\n",
    "        if s[i]==s[i-1]:\n",
    "            c+=1\n",
    "        else:\n",
    "            r+=s[i-1]+str(c)\n",
    "            c=1\n",
    "    r+=s[-1]+str(c)\n",
    "    return r\n",
    "s=input()\n",
    "print(compress(s))\n",
    "    "
   ]
